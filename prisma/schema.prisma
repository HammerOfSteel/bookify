generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum ProjectStatus {
  DRAFT
  READY
  GENERATED
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role         UserRole    @default(USER)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  audiobooks   Audiobook[]
  ebooks       Ebook[]
  ttsProjects  TtsProject[]
}

model Audiobook {
  id                     String             @id @default(cuid())
  title                  String
  description            String             @db.Text
  author                 String
  releaseDate            DateTime?
  metadata               Json?
  chapterCount           Int
  coverImagePath         String?
  status                 ProjectStatus      @default(DRAFT)
  outputPreference       String             @default("AUDIO")
  generatedOutputPath    String?
  generatedTimestampPath String?
  ownerId                String
  owner                  User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  chapters               AudiobookChapter[]
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
}

model AudiobookChapter {
  id              String    @id @default(cuid())
  title           String
  audioPath       String?
  audioOriginalName String?
  position        Int
  durationSeconds Int?
  audiobookId     String
  audiobook       Audiobook @relation(fields: [audiobookId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([audiobookId, position])
}

model Ebook {
  id                  String         @id @default(cuid())
  title               String
  description         String         @db.Text
  author              String
  releaseDate         DateTime?
  metadata            Json?
  theme               String         @default("classic")
  chapterCount        Int
  coverImagePath      String?
  status              ProjectStatus  @default(DRAFT)
  generatedOutputPath String?
  ownerId             String
  owner               User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  chapters            EbookChapter[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model EbookChapter {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  position  Int
  ebookId   String
  ebook     Ebook    @relation(fields: [ebookId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ebookId, position])
}

// ── TTS Projects ────────────────────────────────────────────────────────────

model TtsProject {
  id                  String       @id @default(cuid())
  title               String
  description         String       @db.Text
  author              String
  ttsProvider         String       @default("kokoro_local")
  ttsVoice            String       @default("🇺🇸 🚺 Nicole 🎧")
  ttsSpeed            Float        @default(1.0)
  // Remote provider settings (stored as JSON: {apiKey, baseUrl, model, ...})
  ttsRemoteSettings   Json?
  chapterCount        Int
  status              ProjectStatus @default(DRAFT)
  generatedOutputPaths Json?        // array of per-chapter download paths
  ownerId             String
  owner               User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  chapters            TtsChapter[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model TtsChapter {
  id              String     @id @default(cuid())
  title           String
  textContent     String?    @db.Text
  textFileName    String?
  position        Int
  audioPath       String?
  durationSeconds Int?
  projectId       String
  project         TtsProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([projectId, position])
}
